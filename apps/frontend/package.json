{
  "name": "@ianportfolio/frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:prod": "vite build",
    "preview": "vite preview",
    "test": "vitest --coverage --run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:codegen": "playwright codegen http://localhost:3000",
    "lint": "eslint . --fix"
  },
  "dependencies": {
    "@ianportfolio/shared": "workspace:*",
    "echarts": "^6.1.0",
    "jspdf": "^4.2.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.5",
    "ol": "^10.9.0",
    "pinia": "^3.0.4",
    "three": "^0.184.0",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^20.19.43",
    "@types/three": "^0.184.1",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.5.0",
    "entities": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.5.15",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^9.0.0",
    "vue-tsc": "^3.3.5"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
