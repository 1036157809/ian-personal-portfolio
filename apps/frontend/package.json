{
  "name": "@ianportfolio/frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:prod": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:codegen": "playwright codegen http://localhost:3000",
    "lint": "eslint . --ext .ts,.vue --fix"
  },
  "dependencies": {
    "@ianportfolio/shared": "workspace:*",
    "axios": "^1.6.7",
    "echarts": "^6.0.0",
    "jspdf": "^4.2.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "ol": "^10.9.0",
    "pinia": "^2.1.7",
    "three": "^0.184.0",
    "vue": "^3.4.15",
    "vue-i18n": "^9.9.1",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.4.17",
    "entities": "^8.0.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.35",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^6.0.3",
    "vite": "^5.4.21",
    "vitest": "^2.0.0",
    "vue-tsc": "^3.3.2",
    "eslint": "^9.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "vue-eslint-parser": "^9.0.0",
    "eslint-config-prettier": "^9.0.0"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
