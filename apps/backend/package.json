{
  "name": "@ianportfolio/backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend for Ian's personal portfolio website",
  "main": "dist/index.js",
  "scripts": {
    "dev": "lsof -ti:3001 | xargs kill -9 && ts-node-dev --inspect -r tsconfig-paths/register --respawn --transpile-only --watch src src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "migrate": "ts-node src/database/migrate.ts",
    "test": "vitest --coverage --run",
    "test:watch": "vitest",
    "lint": "eslint . --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ianportfolio/shared": "workspace:*",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.6.0",
    "axios": "^1.18.0",
    "chromadb": "^3.4.3",
    "dotenv": "^17.4.2",
    "ip2region": "^2.3.0",
    "koa": "^3.2.1",
    "koa-body": "^8.0.0",
    "mysql2": "^3.22.5",
    "node-cron": "^4.4.1",
    "openai": "^6.44.0",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "@types/koa": "^3.0.3",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.5",
    "@types/node": "^20.19.43",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
