# ─── 生产环境配置模板 ───────────────────────────────────────
# 复制此文件为 .env.production 并填入真实值
# 注意：DB 连接信息由 docker-compose.yml 的 environment 注入，此处不配置

OPENSKY_CLIENT_ID=your-opensky-client-id
OPENSKY_CLIENT_SECRET=your-opensky-client-secret

# ─── AI Assistant ───────────────────────────────────────────

# LLM (LongCat, 兼容 OpenAI API 格式)
ANTHROPIC_AUTH_TOKEN=your-longcat-api-key
LLM_BASE_URL=https://api.longcat.chat/openai/v1
LLM_MODEL=LongCat-2.0-Preview
LLM_MAX_TOKENS=1024

# ChromaDB (TryChroma 云端)
CHROMADB_API_KEY=your-chroma-api-key
CHROMADB_HOST=api.trychroma.com
CHROMADB_TENANT=your-chroma-tenant-id
CHROMADB_DATABASE=your-chroma-database
CHROMADB_COLLECTION=portfolio-knowledge

# RAG 参数
CHUNK_MAX_SIZE=600
CHUNK_OVERLAP=100
RETRIEVE_TOP_K=5

# 访客统计
VISITOR_SALT=your-visitor-salt
