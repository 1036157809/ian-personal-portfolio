# ─── 本地开发配置 ───────────────────────────────────────
NODE_ENV=development
PORT=3001

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=portfolio

# ─── OpenSky (可选) ────────────────────────────────────
OPENSKY_CLIENT_ID=your_opensky_client_id
OPENSKY_CLIENT_SECRET=your_opensky_client_secret

# ─── AI Assistant (可选，不配也能起服务) ──────────────
ANTHROPIC_AUTH_TOKEN=your_api_token
LLM_BASE_URL=https://api.longcat.chat/openai/v1
LLM_MODEL=LongCat-2.0-Preview
LLM_MAX_TOKENS=1024

# ChromaDB (可选)
CHROMADB_API_KEY=your_chromadb_api_key
CHROMADB_HOST=api.trychroma.com
CHROMADB_TENANT=your_tenant_id
CHROMADB_DATABASE=your_database_name
CHROMADB_COLLECTION=portfolio-knowledge

# RAG
CHUNK_MAX_SIZE=600
CHUNK_OVERLAP=100
RETRIEVE_TOP_K=5

# 前端构建参数（docker-compose 使用）
VITE_TIANDITU_TOKEN=your_tianditu_token
VITE_API_BASE_URL=/api
